# 複製為 .env 後依需求修改；lightsail-bootstrap.sh 會自動產生此檔。

# Django SECRET_KEY；正式環境務必換掉。可用：
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me

# 0 = production；1 = debug（不要在正式環境開）
DJANGO_DEBUG=0

# 逗號分隔，必須包含 public IP 或網域；web container 內部溝通用 'web'
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# host 對外暴露的 port。預設 80 可直接 http:// 訪問（docker daemon 本身是 root，沒問題）
WEB_PORT=80
